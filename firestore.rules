rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidMemory(data, expectedUserId) {
      return data.keys().hasAll(['userId', 'fact', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.userId == expectedUserId &&
             data.fact is string && data.fact.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /users/{userId}/memories/{memoryId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(memoryId) && isValidMemory(incoming(), request.auth.uid);
      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
